# ─────────────────────────────────────────────
#  Videocraft Studio — .gitignore
# ─────────────────────────────────────────────

# ── Secrets & credentials ─────────────────────
.env
.env.local
.env.*.local
secrets.json
oracle.env
*.pem
*.key

# ── Python ────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.venv/
venv/
env/
dist/
build/
*.so

# ── Logs ──────────────────────────────────────
*.log
bot.log
debug_last_output.txt
*.tmp
*.bak
*_backup.*

# ── Node / Next.js ────────────────────────────
node_modules/
.next/
.turbo/
out/
npm-debug.log*
yarn-error.log*

# ── Media — client assets (large binaries) ───
# Audio
*.mp3
*.wav
*.flac
*.ogg
*.aac
*.m4a
*.MP3
# Video (eccetto file di progetto Remotion)
*.mp4
*.mov
*.avi
*.mkv
REMOTION*.mp4
# Raw images (keep thumbnails/reference frames generated by code)
CLIENTI/*/COPERTINE/
CLIENTI/*/VIDEO/
CLIENTI/*/AUDIO/
CLIENTI/*/Musica/

# ── Style Library ─────────────────────────────
# I frames estratti sono grandi e riproducibili — il profile JSON va in git
styles/*/frames/
# Workspace temporanei degli agenti
agents/*/workspace/
# Directory root-level legacy (ancorate con / per non colpire agents/)
/copywriter/
/cover-designer/
/marketing-manager/
/smm-publisher/
/smm-researcher/
/strategist/
/video-editor/

# ── Remotion / Video Editor ───────────────────
video-editor/node_modules/
video-editor/out/
video-editor/public/

# ── Dashboard ────────────────────────────────
dashboard/node_modules/
dashboard/.next/
dashboard/out/

# ── Runtime data (generati automaticamente, non versionare) ──
analytics_cache.json
smm_log.json
tts_config.json
topics.json
piano_editoriale.json

# ── B-roll cache (file scaricati, riproducibili) ──────────────
broll_cache/
CODICE/video-editor/public/broll/
CODICE/video-editor/public/voiceover.mp3
CODICE/video-editor/public/timeline.json

# ── Backup e file temporanei ──────────────────────────────────
*_backup.py
bot_telegram_backup.py
llm.txt
llm_try2.txt
test_ideogram.png
deploy/

# ── Misc OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
