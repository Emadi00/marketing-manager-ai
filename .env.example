# ─────────────────────────────────────────────
#  Videocraft Studio — variabili d'ambiente
#  Copia in .env e compila con i valori reali.
#  NON committare il .env vero.
# ─────────────────────────────────────────────

# ── Anthropic ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Telegram ──────────────────────────────────
TELEGRAM_TOKEN=1234567890:AAF...

# ── Upload-Post (SMM Publisher) ───────────────
UPLOAD_POST_API_KEY=...
UPLOAD_POST_WEBHOOK_URL=https://tuodominio.com/webhook/upload-post
UPLOAD_POST_WEBHOOK_PORT=5001

# ── Ideogram ──────────────────────────────────
IDEOGRAM_API_KEY=...

# ── Percorsi (opzionale — usa i default se vuoti) ─
# BASE_PATH=C:\Users\super\Desktop\MARKETING MANAGER
# SECRETS_PATH=C:\Users\super\Desktop\ai-command-center\data\secrets.json

# ── Dashboard ─────────────────────────────────
# Usata dal bot per pushare aggiornamenti pipeline
DASHBOARD_URL=http://localhost:3000

# ── ElevenLabs (TTS voiceover) ───────────────────────
# Chiave su: https://elevenlabs.io/app/settings/api-keys
# Usata da tts_engine.py — alternativa: secrets.json > elevenlabs > apiKey
ELEVENLABS_API_KEY=...

# ── Pexels (B-roll finder) ───────────────────────
# Chiave su: https://www.pexels.com/api/ (gratuita, 200 req/h)
# Usata da broll_finder.py — alternativa: secrets.json > pexels > apiKey
PEXELS_API_KEY=...
PIXABAY_API_KEY=...

# ── fal.ai (Flux image generation) ──────────────────
# Chiave su: https://fal.ai/dashboard/keys
FAL_KEY=...
